# Copy to .env.local for personal overrides (optional).
#
#   cp .env.local.example .env.local
#
# Do NOT set NEXT_PUBLIC_API_BASE_URL here — remote URL comes from `.env`.
# For local API only, run: npm run dev:local

# Auth mode for local work
NEXT_PUBLIC_BYPASS_AUTH=true

# Dev session (when NEXT_PUBLIC_BYPASS_AUTH=true)
NEXT_PUBLIC_DEV_COMPANY_ID=
NEXT_PUBLIC_DEV_EMAIL=
NEXT_PUBLIC_DEV_PASSWORD=
NEXT_PUBLIC_DEV_NAME=

# Optional: paste a token instead of email/password auto-login
NEXT_PUBLIC_DEV_ID_TOKEN=

# Firebase (when NEXT_PUBLIC_BYPASS_AUTH=false)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
