# Backend API
# Used by the central Axios client for all EMSYS API requests.
# API root including version prefix.
# Used by `npm run dev` / `npm run dev:remote`, build, and start.
# Example: https://api.embarqueros.com/v1
# For local API, use: npm run dev:local (overrides to http://localhost:8080/v1)
# Browser calls this URL directly — API CORS must allow the portal origin (e.g. http://localhost:3000).
NEXT_PUBLIC_API_BASE_URL=https://api.embarqueros.com/v1

# Authentication
# false = Firebase login (recommended for full API + permissions testing).
# true  = dev bypass (development only): skip Firebase UI, use dev session below.
NEXT_PUBLIC_BYPASS_AUTH=false

# Dev bypass / auto-login: use .env.local (see .env.local.example).

# Firebase web app config
# Firebase is used for authentication. Firestore users/{uid} stores only:
# companyId, email, name (role/permissions come from the backend API).
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Optional: skip Firestore users/{uid} lookup (use JWT companyId claim only)
NEXT_PUBLIC_DISABLE_FIRESTORE_PROFILE=false
